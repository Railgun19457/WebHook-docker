WEBHOOK_BIND_ADDR=0.0.0.0
WEBHOOK_BIND_PORT=8080
WEBHOOK_LOG_LEVEL=info
WEBHOOK_CONFIG_PATH=/app/config/webhook.yaml
WEBHOOK_DEFAULT_TIMEOUT_SECONDS=60
WEBHOOK_EXECUTION_MODE=local

SSH_PRIVATE_KEY_PATH=/run/secrets/id_rsa
SSH_PASSPHRASE=
SSH_KNOWN_HOSTS_PATH=/app/data/known_hosts

GITHUB_BLOG_WEBHOOK_SECRET=replace-with-real-secret
